{
  "name": "zolangola-server",
  "version": "1.0.0",
  "description": "Backend server for ZOLANGOLA platform - Site, Admin, Candidato e Empresa",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node server.ts",
    "build": "tsc",
    "build:check": "node --version && tsc",
    "start": "node dist/server.js",
    "vercel-build": "npm run build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "migrate": "ts-node src/database/migrate.ts",
    "migrate:news": "ts-node src/database/run-news-migration.ts",
    "migrate:production": "ts-node src/scripts/migrate-to-production.ts",
    "test:production": "ts-node src/scripts/test-production-connection.ts",
    "seed": "ts-node src/database/seed.ts"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "vercel": {
    "buildCommand": "npm run vercel-build",
    "outputDirectory": "dist",
    "installCommand": "npm install",
    "framework": null
  },
  "keywords": [
    "node",
    "express",
    "mysql",
    "typescript",
    "zolangola"
  ],
  "author": "Laboratório Softhard",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@types/multer": "^2.0.0",
    "@types/nodemailer": "^7.0.4",
    "@vercel/blob": "^2.0.0",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.2.0",
    "firebase-admin": "^13.6.0",
    "google-auth-library": "^9.0.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "mysql2": "^3.15.3",
    "nodemailer": "^7.0.11",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.5",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.5",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "eslint": "^9.18.0",
    "nodemon": "^3.1.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
